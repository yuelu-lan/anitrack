spring:
  datasource:
    username: root
    password: your-local-mysql-password
  flyway:
    locations: classpath:db/migration,classpath:db/migration-dev

anitrack:
  jwt:
    secret: your-jwt-secret-base64-at-least-32-bytes
  rag:
    # 需与 rag-service/.env 的 INTERNAL_TOKEN 一致，否则 Java→rag-service 鉴权 401
    internal-token: your-rag-internal-token
    base-url: http://localhost:8081
  bangumi:
    # 国内访问 api.bgm.tv 需 http 代理，留空则不走代理（兼容生产/无代理环境）
    proxy-host: 127.0.0.1
    proxy-port: 7897
